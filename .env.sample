# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.sample` is committed as a template.

# Grist API key — generate from profile settings at https://docs.getgrist.com
GRIST_API_KEY=

# Grist document id — the segment after `/doc/` in the document URL
GRIST_DOC_ID=

# Optional, only for self-hosted Grist. Defaults to https://docs.getgrist.com/api
# GRIST_BASE_URL=https://your-grist-host/api
